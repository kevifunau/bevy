{
  "version": "2.0",
  "scene_name": "RelativeCursorPosition",
  "root": {
    "id": "relative_cursor_root",
    "type": "Node",
    "styles": {
      "width": "100%",
      "height": "100%",
      "align_items": "center",
      "justify_content": "center",
      "flex_direction": "column"
    },
    "children": [
      {
        "id": "cursor_box",
