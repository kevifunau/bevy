        },
        "visuals": {
          "background_color": "#EA240D"
        }
      },
      {
        "id": "cursor_output",
        "type": "Text",
        "text_config": {
          "content": "(0.0, 0.0)",
          "font_size": 33,
          "font_color": "#E6E6E6",
          "font_path": "fonts/FiraSans-Bold.ttf"
        }
      }
    ]
  }
}
