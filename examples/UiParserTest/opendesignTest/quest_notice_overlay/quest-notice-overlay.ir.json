{
  "version": "3.0-ir",
  "scene_name": "OpenDesignHtmlScene",
  "root": {
    "id": "overlay_root",
    "kind": "node",
    "markers": [
      "class:overlay"
    ],
    "layout": {
      "styles": {
        "display": "flex",
        "width": "100%",
        "height": "100%",
        "left": "0",
        "right": "0",
        "top": "0",
        "bottom": "0",
        "padding": "24px",
        "justify_content": "center",
        "align_items": "center",
        "position_type": "absolute",
        "fixed_node": true
      }
    },
    "style": {
      "visuals": {
        "background_color": "#00000094"
      }
    },
    "children": [
      {
        "id": "panel",
        "kind": "node",
        "markers": [
          "class:panel"
        ],
        "layout": {
          "styles": {
            "display": "flex",
            "width": "620px",
            "max_height": "518.4px",
            "padding": "28px",
            "flex_direction": "column",
            "row_gap": "18px",
            "column_gap": "18px"
          }
        },
        "style": {
          "visuals": {
            "background_color": "#f8ecd0",
            "border_color": "#8b5f33",
            "border_width": "4px",
            "border_radius": "24px"
          }
        },
        "children": [
          {
            "id": "notice_head",
            "kind": "node",
            "markers": [
              "class:notice-head"
            ],
            "layout": {
              "styles": {
                "display": "flex",
                "flex_direction": "column",
                "row_gap": "8px",
                "column_gap": "8px",
                "align_items": "center"
              }
            },
            "children": [
              {
                "id": "notice_title",
                "kind": "node",
                "markers": [
                  "class:notice-title"
                ],
                "layout": {
                  "styles": {
                    "margin": "0"
                  }
                },
                "children": [
                  {
                    "id": "notice_title_text_1",
                    "kind": "text",
                    "content": {
                      "text": {
                        "content": "新的委托",
                        "font_size": 40.0,
                        "font_color": "#3b2818",
                        "font_path": "Songti.ttc"
                      }
                    }
                  }
                ]
              },
              {
                "id": "notice_subtitle",
                "kind": "node",
                "markers": [
                  "class:notice-subtitle"
                ],
                "children": [
                  {
                    "id": "notice_subtitle_text_1",
                    "kind": "text",
                    "content": {
                      "text": {
                        "content": "村长正在寻找可靠的冒险者。",
                        "font_size": 15.0,
                        "font_color": "#79614b",
                        "font_path": "Songti.ttc"
                      }
                    }
                  }
                ]
              }
            ]
          },
          {
            "id": "quest_card",
            "kind": "node",
            "markers": [
              "class:quest-card"
            ],
            "layout": {
              "styles": {
                "display": "flex",
                "padding": "18px",
                "flex_direction": "column",
                "row_gap": "12px",
                "column_gap": "12px"
              }
            },
            "style": {
              "visuals": {
                "background_color": "#FFFFFFCC",
                "border_color": "#8b5f33",
                "border_width": "2px",
                "border_radius": "18px"
              }
            },
            "children": [
              {
                "id": "quest_name",
                "kind": "node",
                "markers": [
                  "class:quest-name"
                ],
                "children": [
                  {
                    "id": "quest_name_text_1",
                    "kind": "text",
                    "content": {
                      "text": {
                        "content": "修复东桥",
                        "font_size": 26.0,
                        "font_color": "#3b2818",
                        "font_path": "Songti.ttc"
                      }
                    }
                  }
                ]
              },
              {
                "id": "quest_desc",
                "kind": "node",
                "markers": [
                  "class:quest-desc"
                ],
                "children": [
                  {
                    "id": "quest_desc_text_1",
                    "kind": "text",
                    "content": {
                      "text": {
                        "content": "收集木材并协助工匠修复通往果园的旧桥。",
                        "font_size": 15.0,
                        "font_color": "#79614b",
                        "font_path": "Songti.ttc"
                      }
                    }
                  }
                ]
              },
              {
                "id": "reward_row",
                "kind": "node",
                "markers": [
                  "class:reward-row"
                ],
                "layout": {
                  "styles": {
                    "display": "flex",
                    "padding": "12px 14px",
                    "justify_content": "space-between",
                    "align_items": "center"
                  }
                },
                "style": {
                  "visuals": {
                    "background_color": "#D89A1F2E",
                    "border_radius": "14px"
                  }
                },
                "children": [
                  {
                    "id": "reward_label",
                    "kind": "node",
                    "markers": [
                      "class:reward-label"
                    ],
                    "children": [
                      {
                        "id": "reward_label_text_1",
                        "kind": "text",
                        "content": {
                          "text": {
                            "content": "完成奖励",
                            "font_size": 14.0,
                            "font_color": "#79614b",
                            "font_path": "Songti.ttc"
                          }
                        }
                      }
                    ]
                  },
                  {
                    "id": "reward_value",
                    "kind": "node",
                    "markers": [
                      "class:reward-value"
                    ],
                    "children": [
                      {
                        "id": "reward_value_text_1",
                        "kind": "text",
                        "content": {
                          "text": {
                            "content": "+240 金币",
                            "font_size": 28.0,
                            "font_color": "#d89a1f",
                            "font_path": "Songti.ttc"
                          }
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "id": "notice_actions",
            "kind": "node",
            "markers": [
              "class:notice-actions"
            ],
            "layout": {
              "styles": {
                "display": "flex",
                "row_gap": "14px",
                "column_gap": "14px",
                "justify_content": "flex-end"
              }
            },
            "children": [
              {
                "id": "secondary_btn",
                "kind": "button",
                "markers": [
                  "class:secondary-btn"
                ],
                "actions": [
                  {
                    "event": "press",
                    "emit": "dismiss_notice"
                  }
                ],
                "layout": {
                  "styles": {
                    "display": "flex",
                    "height": "52px",
                    "min_width": "128px",
                    "justify_content": "center",
                    "align_items": "center"
                  }
                },
                "style": {
                  "visuals": {
                    "background_color": "#8b5f33",
                    "border_width": "0",
                    "border_radius": "999px"
                  }
                },
                "state_visuals": {
                  "normal": {
                    "styles": {
                      "ui_scale": "1 1"
                    }
                  },
                  "pressed": {
                    "styles": {
                      "ui_scale": "0.96 0.96"
                    }
                  }
                },
                "children": [
                  {
                    "id": "secondary_btn_text_1",
                    "kind": "text",
                    "content": {
                      "text": {
                        "content": "稍后",
                        "font_size": 20.0,
                        "font_color": "#FFFFFF",
                        "font_path": "Songti.ttc"
                      }
                    }
                  }
                ]
              },
              {
                "id": "primary_btn",
                "kind": "button",
                "markers": [
                  "class:primary-btn"
                ],
                "actions": [
                  {
                    "event": "press",
                    "emit": "accept_quest"
                  }
                ],
                "layout": {
                  "styles": {
                    "display": "flex",
                    "height": "52px",
                    "min_width": "128px",
                    "justify_content": "center",
                    "align_items": "center"
                  }
                },
                "style": {
                  "visuals": {
                    "background_color": "#3db760",
                    "border_width": "0",
                    "border_radius": "999px"
                  }
                },
                "state_visuals": {
                  "pressed": {
                    "styles": {
                      "ui_scale": "0.96 0.96"
                    }
                  },
                  "normal": {
                    "styles": {
                      "ui_scale": "1 1"
                    }
                  }
                },
                "children": [
                  {
                    "id": "primary_btn_text_1",
                    "kind": "text",
                    "content": {
                      "text": {
                        "content": "接受",
                        "font_size": 20.0,
                        "font_color": "#FFFFFF",
                        "font_path": "Songti.ttc"
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}