{
  "version": "2.0",
  "scene_name": "UiTextureAtlas",
  "root": {
    "id": "ui_texture_atlas_root",
    "type": "Node",
    "styles": {
      "width": "100%",
      "height": "100%",
      "flex_direction": "column",
      "justify_content": "center",
      "align_items": "center",
      "row_gap": "40px"
    },
    "children": [
      {
        "id": "atlas_image",
        "type": "Image",
        "styles": {
          "width": "256px",
          "height": "256px"
        },
        "visuals": {
          "background_color": "#FAEBD7",
          "border_color": "#DC143C",
          "border_width": "8px"
        },
        "image_config": {
          "texture_path": "textures/rpg/chars/gabe/gabe-idle-run.png",
          "atlas": {
            "tile_width": 24,
            "tile_height": 24,
            "columns": 7,
            "rows": 1,
            "index": 0
          }
        }
      },
      {
        "id": "atlas_hint_row",
        "type": "Node",
        "styles": {
          "flex_direction": "row",
          "align_items": "center"
        },
        "children": [
          {
            "id": "atlas_hint_prefix",
            "type": "Text",
            "text_config": {
              "content": "press ",
              "font_size": 20,
              "font_color": "#FFFFFF"
            }
          },
          {
            "id": "atlas_hint_key",
            "type": "Text",
            "text_config": {
              "content": "space",
              "font_size": 20,
              "font_color": "#FFFF00"
            }
          },
          {
            "id": "atlas_hint_suffix",
            "type": "Text",
            "text_config": {
              "content": " to advance frames",
              "font_size": 20,
              "font_color": "#FFFFFF"
            }
          }
        ]
      }
    ]
  }
}
