{
  "version": "2.0",
  "scene_name": "ButtonWidget",
  "root": {
    "id": "button_root",
    "type": "Node",
    "styles": {
      "width": "100%",
      "height": "100%",
      "align_items": "center",
      "justify_content": "center"
    },
    "children": [
      {
        "id": "main_button",
        "type": "Button",
        "styles": {
          "width": "150px",
          "height": "65px",
          "justify_content": "center",
          "align_items": "center"
        },
        "visuals": {
          "background_color": "#000000",
          "border_color": "#FFFFFF",
          "border_width": "5px",
          "border_radius": "9999px"
        },
        "children": [
          {
            "id": "main_button_text",
            "type": "Text",
            "text_config": {
              "content": "Button",
              "font_size": 33,
              "font_color": "#E6E6E6",
              "font_path": "fonts/FiraSans-Bold.ttf",
              "text_shadow": {}
            }
          }
        ]
      }
    ]
  }
}
