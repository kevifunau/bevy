{
  "version": "2.0",
  "scene_name": "LoginScreen",
  "root": {
    "id": "login_root_container",
    "type": "Node",
    "styles": {
      "width": "100%",
      "height": "100%",
      "flex_direction": "column",
      "justify_content": "center",
      "align_items": "center"
    },
    "children": [
      {
        "id": "login_interaction_panel",
        "type": "Node",
        "styles": {
          "flex_direction": "column",
          "align_items": "center",
          "padding": "20px",
          "margin_top": "150px"
        },
        "children": [
          {
            "id": "account_row",
            "type": "Node",
            "styles": {
              "width": "320px",
              "height": "45px",
              "margin_bottom": "10px",
              "flex_direction": "row",
              "align_items": "center",
              "padding": "0px 15px"
            },
            "visuals": {
              "background_color": "#111111B3",
              "border_color": "#888888",
              "border_width": "2px",
              "border_radius": "8px"
            },
            "children": [
              {
                "id": "lbl_account",
                "type": "Text",
                "text_config": {
                  "content": "账号：",
                  "font_size": 18,
                  "font_color": "#FFFFFF",
                  "font_path": "fonts/simhei.ttf"
                }
              },
              {
                "id": "input_account",
                "type": "TextInput",
                "styles": {
                  "flex_grow": "1",
                  "margin_left": "8px"
                },
                "text_config": {
                  "content": "",
                  "placeholder": "请输入账号",
                  "font_size": 18,
                  "font_color": "#FFFFFF",
                  "font_path": "fonts/simhei.ttf"
                }
              }
            ]
          },
          {
            "id": "password_row",
            "type": "Node",
            "styles": {
              "width": "320px",
              "height": "45px",
              "margin_bottom": "15px",
              "flex_direction": "row",
              "align_items": "center",
              "padding": "0px 15px"
            },
            "visuals": {
              "background_color": "#111111B3",
              "border_color": "#888888",
              "border_width": "2px",
              "border_radius": "8px"
            },
            "children": [
              {
                "id": "lbl_password",
                "type": "Text",
                "text_config": {
                  "content": "密码：",
                  "font_size": 18,
                  "font_color": "#FFFFFF",
                  "font_path": "fonts/simhei.ttf"
                }
              },
              {
                "id": "input_password",
                "type": "TextInput",
                "styles": {
                  "flex_grow": "1",
                  "margin_left": "8px"
                },
                "text_config": {
                  "content": "",
                  "placeholder": "请输入密码",
                  "font_size": 18,
                  "font_color": "#FFFFFF",
                  "font_path": "fonts/simhei.ttf"
                }
              }
            ]
          },
          {
            "id": "checkbox_group",
            "type": "Node",
            "styles": {
              "width": "320px",
              "flex_direction": "row",
              "justify_content": "center",
              "margin_bottom": "25px"
            },
            "children": [
              {
                "id": "cb_remember_pwd",
                "type": "Toggle",
                "styles": {
                  "flex_direction": "row",
                  "align_items": "center",
                  "margin_right": "20px"
                },
                "children": [
                  {
                    "id": "icon_rem_box",
                    "type": "Node",
                    "styles": {
                      "width": "18px",
                      "height": "18px",
                      "margin_right": "8px"
                    },
                    "visuals": {
                      "background_color": "#333333",
                      "border_width": "1px",
                      "border_color": "#AAAAAA"
                    }
                  },
                  {
                    "id": "txt_rem_pwd",
                    "type": "Text",
                    "text_config": {
                      "content": "记住密码",
                      "font_size": 16,
                      "font_color": "#FFFFFF",
                      "font_path": "fonts/simhei.ttf"
                    }
                  }
                ]
              },
              {
                "id": "cb_auto_login",
                "type": "Toggle",
                "styles": {
                  "flex_direction": "row",
                  "align_items": "center"
                },
                "children": [
                  {
                    "id": "icon_auto_box",
                    "type": "Node",
                    "styles": {
                      "width": "18px",
                      "height": "18px",
                      "margin_right": "8px"
                    },
                    "visuals": {
                      "background_color": "#333333",
                      "border_width": "1px",
                      "border_color": "#AAAAAA"
                    }
                  },
                  {
                    "id": "txt_auto_login",
                    "type": "Text",
                    "text_config": {
                      "content": "自动登录",
                      "font_size": 16,
                      "font_color": "#FFFFFF",
                      "font_path": "fonts/simhei.ttf"
                    }
                  }
                ]
              }
            ]
          },
          {
            "id": "button_group",
            "type": "Node",
            "styles": {
              "width": "320px",
              "flex_direction": "row",
              "justify_content": "space_between"
            },
            "children": [
              {
                "id": "btn_register",
                "type": "Button",
                "custom_tags": ["Sound_Click", "Nav_To_Register"],
                "styles": {
                  "width": "120px",
                  "height": "45px",
                  "justify_content": "center",
                  "align_items": "center"
                },
                "visuals": {
                  "background_color": "#0077CC",
                  "border_color": "#88FFFF",
                  "border_width": "2px",
                  "border_radius": "6px"
                },
                "children": [
                  {
                    "id": "txt_btn_reg",
                    "type": "Text",
                    "text_config": {
                      "content": "注册",
                      "font_size": 20,
                      "font_color": "#FFFFFF",
                      "font_path": "fonts/simhei.ttf"
                    }
                  }
                ]
              },
              {
                "id": "btn_confirm",
                "type": "Button",
                "custom_tags": ["Sound_Click", "Action_Submit_Login"],
                "styles": {
                  "width": "120px",
                  "height": "45px",
                  "justify_content": "center",
                  "align_items": "center"
                },
                "visuals": {
                  "background_color": "#0077CC",
                  "border_color": "#88FFFF",
                  "border_width": "2px",
                  "border_radius": "6px"
                },
                "children": [
                  {
                    "id": "txt_btn_conf",
                    "type": "Text",
                    "text_config": {
                      "content": "确定",
                      "font_size": 20,
                      "font_color": "#FFFFFF",
                      "font_path": "fonts/simhei.ttf"
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
