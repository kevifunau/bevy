{
  "version": "2.0",
  "scene_name": "TextInput",
  "root": {
    "id": "text_input_root",
    "type": "Node",
    "styles": {
      "align_items": "center",
      "flex_direction": "column",
      "padding": "20px",
      "row_gap": "16px",
      "margin": "auto"
    },
    "children": [
      {
        "id": "text_input_instructions",
        "type": "Text",
        "text_config": {
          "content": "Enter to submit text\nTab to switch inputs",
          "font_size": 25,
          "font_color": "#FFFFFF",
          "font_path": "fonts/FiraSans-Bold.ttf"
        }
      },
      {
        "id": "text_input_container",
        "type": "Node",
        "styles": {
          "column_gap": "16px",
          "auto_focus": true,
          "tab_group": "0"
        },
        "children": [
          {
            "id": "text_input_left",
            "type": "TextInput",
            "styles": {
              "tab_index": "0"
            },
            "visuals": {
              "border_color": "#CBD5E1",
              "border_width": "2px",
              "background_color": "#A9A9A9"
            },
            "text_config": {
              "content": "",
              "font_size": 24,
              "font_color": "#FFFFFF",
              "visible_width": 10,
              "allow_newlines": false,
              "linebreak": "no_wrap"
            }
          },
          {
            "id": "text_input_right",
            "type": "TextInput",
            "styles": {
              "tab_index": "1"
            },
            "visuals": {
              "border_color": "#CBD5E1",
              "border_width": "2px",
              "background_color": "#A9A9A9"
            },
            "text_config": {
              "content": "",
              "font_size": 24,
              "font_color": "#FFFFFF",
              "visible_width": 10,
              "allow_newlines": false,
              "linebreak": "no_wrap"
            }
          }
        ]
      },
      {
        "id": "text_output_box",
        "type": "Node",
        "styles": {
          "width": "400px",
          "padding": "8px"
        },
        "visuals": {
          "border_color": "#CBD5E1",
          "border_width": "2px"
        },
        "children": [
          {
            "id": "text_output_text",
            "type": "Text",
            "custom_tags": ["TextOutput"],
            "text_config": {
              "content": "",
              "font_size": 24,
              "font_color": "#FFFFFF",
              "linebreak": "word_or_character"
            }
          }
        ]
      }
    ]
  }
}
