{
  "version": "2.0",
  "scene_name": "ImageNodeResizing",
  "root": {
    "id": "image_node_resizing_root",
    "type": "Node",
    "styles": {
      "display": "grid",
      "width": "100%",
      "height": "100%",
      "grid_template_rows": "min_content(1) flex(1,1)"
    },
    "visuals": {
      "background_color": "#FFFFFF"
    },
    "children": [
      {
        "id": "resize_status_text",
        "type": "Text",
        "styles": {
          "grid_row": "span(1)",
          "padding": "6px"
        },
        "text_config": {
          "content": "Compare NodeImageMode(Auto, Stretch) press `Up`/`Down` to resize height, press `Left`/`Right` to resize width\nheight : 30%, width : 75%",
          "font_size": 14,
          "font_color": "#000000"
        }
      },
      {
        "id": "image_groups_container",
        "type": "Node",
        "styles": {
          "display": "flex",
          "grid_row": "span(1)",
          "flex_direction": "column",
          "justify_content": "space_around",
          "padding": "10px"
        },
        "visuals": {
          "background_color": "#000000"
        },
        "children": [
          {
            "id": "auto_image_group",
            "type": "Node",
            "styles": {
              "width": "75%",
              "height": "30%",
              "justify_content": "start"
            },
            "visuals": {
              "background_color": "#DBEAFE"
            },
            "children": [
              {
                "id": "auto_icon_1",
                "type": "Image",
                "image_config": {
                  "texture_path": "branding/icon.png",
                  "image_mode": "auto"
                }
              },
              {
                "id": "auto_icon_2",
                "type": "Image",
                "image_config": {
                  "texture_path": "branding/icon.png",
                  "image_mode": "auto"
                }
              },
              {
                "id": "auto_icon_3",
                "type": "Image",
                "image_config": {
                  "texture_path": "branding/icon.png",
                  "image_mode": "auto"
                }
              },
              {
                "id": "auto_icon_4",
                "type": "Image",
                "image_config": {
                  "texture_path": "branding/icon.png",
                  "image_mode": "auto"
                }
              }
            ]
          },
          {
            "id": "stretch_image_group",
            "type": "Node",
            "styles": {
              "width": "75%",
              "height": "30%",
              "justify_content": "start"
            },
            "visuals": {
              "background_color": "#DBEAFE"
            },
            "children": [
              {
                "id": "stretch_icon_10",
                "type": "Image",
                "styles": {
                  "width": "10%",
                  "height": "100%"
                },
                "image_config": {
                  "texture_path": "branding/icon.png",
                  "image_mode": "stretch"
                }
              },
              {
                "id": "stretch_icon_20",
                "type": "Image",
                "styles": {
                  "width": "20%",
                  "height": "100%"
                },
                "image_config": {
                  "texture_path": "branding/icon.png",
                  "image_mode": "stretch"
                }
              },
              {
                "id": "stretch_icon_30",
                "type": "Image",
                "styles": {
                  "width": "30%",
                  "height": "100%"
                },
                "image_config": {
                  "texture_path": "branding/icon.png",
                  "image_mode": "stretch"
                }
              },
              {
                "id": "stretch_icon_40",
                "type": "Image",
                "styles": {
                  "width": "40%",
                  "height": "100%"
                },
                "image_config": {
                  "texture_path": "branding/icon.png",
                  "image_mode": "stretch"
                }
              }
            ]
          }
        ]
      }
    ]
  }
}
