{
  "version": "3.0-ir",
  "scene_name": "ImageNodeResizing",
  "imports": [],
  "state_model": {},
  "resources": {},
  "root": {
    "id": "image_node_resizing_root",
    "kind": "node",
    "layout": {
      "styles": {
        "display": "grid",
        "width": "100%",
        "height": "100%",
        "grid_template_rows": "min_content(1) flex(1,1)"
      }
    },
    "style": {
      "visuals": {
        "background_color": "#FFFFFF"
      }
    },
